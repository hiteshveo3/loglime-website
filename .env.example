NEXT_PUBLIC_SITE_URL=https://loglime.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional legacy name supported by the code.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SMTP settings for email subscribe forms.
# Example providers: Brevo, Gmail app password, Zoho Mail, Mailgun, SendGrid SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Loglime <hello@loglime.com>"
SUBSCRIBE_NOTIFY_TO=hello@loglime.com
SUBSCRIBE_SEND_CONFIRMATION=true
